<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="https://jakarta.ee/xml/ns/jakartaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="https://jakarta.ee/xml/ns/jakartaee
         https://jakarta.ee/xml/ns/jakartaee/web-app_5_0.xsd"
         version="5.0">

    <servlet>
        <servlet-name>SignupServlet</servlet-name>
        <servlet-class>com.grocery.SignupServlet</servlet-class>
    </servlet>

    <servlet-mapping>
        <servlet-name>SignupServlet</servlet-name>
        <url-pattern>/signup</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>LoginServlet</servlet-name>
        <servlet-class>com.grocery.LoginServlet</servlet-class>
    </servlet>

    <servlet-mapping>
        <servlet-name>LoginServlet</servlet-name>
        <url-pattern>/login</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>AddToCartServlet</servlet-name>
        <servlet-class>com.grocery.AddToCartServlet</servlet-class>
    </servlet>

    <servlet-mapping>
        <servlet-name>AddToCartServlet</servlet-name>
        <url-pattern>/addtocart</url-pattern>
    </servlet-mapping>

   <servlet>
    <servlet-name>LogoutServlet</servlet-name>
    <servlet-class>com.grocery.LogoutServlet</servlet-class>
</servlet>

<servlet-mapping>
    <servlet-name>LogoutServlet</servlet-name>
    <url-pattern>/logout</url-pattern>
</servlet-mapping>
    <servlet>
    <servlet-name>RemoveFromCartServlet</servlet-name>
    <servlet-class>com.grocery.RemoveFromCartServlet</servlet-class>
</servlet>

<servlet-mapping>
    <servlet-name>RemoveFromCartServlet</servlet-name>
    <url-pattern>/removefromcart</url-pattern>
</servlet-mapping>
<servlet>
    <servlet-name>PlaceOrderServlet</servlet-name>
    <servlet-class>com.grocery.PlaceOrderServlet</servlet-class>
</servlet>

<servlet-mapping>
    <servlet-name>PlaceOrderServlet</servlet-name>
    <url-pattern>/placeorder</url-pattern>
</servlet-mapping>
<servlet>
    <servlet-name>AddProductServlet</servlet-name>
    <servlet-class>com.grocery.AddProductServlet</servlet-class>
</servlet>

<servlet-mapping>
    <servlet-name>AddProductServlet</servlet-name>
    <url-pattern>/addproduct</url-pattern>
</servlet-mapping>
<servlet>
    <servlet-name>DeleteProductServlet</servlet-name>
    <servlet-class>com.grocery.DeleteProductServlet</servlet-class>
</servlet>

<servlet-mapping>
    <servlet-name>DeleteProductServlet</servlet-name>
    <url-pattern>/deleteproduct</url-pattern>
</servlet-mapping>

<servlet>
    <servlet-name>EditProductServlet</servlet-name>
    <servlet-class>com.grocery.EditProductServlet</servlet-class>
</servlet>

<servlet-mapping>
    <servlet-name>EditProductServlet</servlet-name>
    <url-pattern>/editproduct</url-pattern>
</servlet-mapping>
<servlet>
    <servlet-name>UpdateOrderStatusServlet</servlet-name>
    <servlet-class>com.grocery.UpdateOrderStatusServlet</servlet-class>
</servlet>

<servlet-mapping>
    <servlet-name>UpdateOrderStatusServlet</servlet-name>
    <url-pattern>/updateorderstatus</url-pattern>
</servlet-mapping>

</web-app>
   